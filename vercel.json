{
  "version": 2,
  "buildCommand": "npm install && npm --prefix backend install && npm --prefix frontend-react run build",
  "outputDirectory": "frontend-react/dist",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.js"
    },
    {
      "src": "/[^.]+$",
      "dest": "frontend-react/dist/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "frontend-react/dist/$1"
    }
  ],
  "env": {
    "DATABASE_URL": "@database_url",
    "JWT_SECRET": "@jwt_secret",
    "FRONTEND_URL": "@frontend_url",
    "NODE_ENV": "production"
  }
}
